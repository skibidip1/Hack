end

-- Hàm đợi Full Moon
local function waitForFullMoon()
    updateUIStatus("Đang đợi Full Moon")
    local isFullMoon = false
    local maxWaitTime = 600
    local elapsedTime = 0

    while not isFullMoon and elapsedTime < maxWaitTime do
        local moon = workspace:FindFirstChild("FullMoon")
        if moon then
            isFullMoon = true
            updateUIStatus("Đã phát hiện Full Moon")
            print("Đã phát hiện Full Moon")
        else
            updateUIStatus("Chưa phải Full Moon, đợi " .. elapsedTime .. "/" .. maxWaitTime .. "s")
            warn("Chưa phải Full Moon, đang đợi...")
            wait(30)
            elapsedTime = elapsedTime + 30
        end
    end

    if isFullMoon then
        local character = LocalPlayer.Character
        if character and moon then
            local humanoidRootPart = character.HumanoidRootPart
            humanoidRootPart.CFrame = CFrame.new(humanoidRootPart.Position, moon.Position)
            updateUIStatus("Đã nhìn vào Full Moon")
            print("Đã nhìn vào Full Moon")
        end
        return true
    else
        updateUIStatus("Hết thời gian đợi Full Moon")
        warn("Hết thời gian đợi Full Moon")
        return false
    end
end

-- Hàm nhặt bánh răng
local function collectGear()
    local character = LocalPlayer.Character
    if not character or not character:FindFirstChild("HumanoidRootPart") then
        updateUIStatus("Nhân vật chưa spawn")
        warn("Nhân vật chưa spawn")
        return false
    end

    local mirageIsland = workspace:FindFirstChild("MirageIsland")
    if not mirageIsland then
        updateUIStatus("Không tìm thấy Mirage Island")
        warn("Không tìm thấy Mirage Island")
        return false
    end

    updateUIStatus("Đang tìm bánh răng")
    local gear = mirageIsland:FindFirstChild("Gear")
    if not gear then
        updateUIStatus("Không tìm thấy bánh răng")
        warn("Không tìm thấy bánh răng")
        return false
    end

    local humanoidRootPart = character.HumanoidRootPart
    humanoidRootPart.CFrame = CFrame.new(gear.Position + Vector3.new(0, 5, 0))

    if gear:FindFirstChild("ProximityPrompt") then
        updateUIStatus("Đang nhặt bánh răng")
        fireproximityprompt(gear.ProximityPrompt)
        updateUIStatus("Đã nhặt bánh răng")
        print("Đã nhặt bánh răng")
        return true
    else
        updateUIStatus("Không tìm thấy ProximityPrompt")
        warn("Không tìm thấy ProximityPrompt trên bánh răng")
        return false
    end
end

-- Hàm chính
local function main()
    showNotification()
    local jobIds = scrapeAPI()
    if not jobIds or #jobIds == 0 then
        updateUIStatus("Không có dữ liệu JobId để hop server")
        warn("Không có dữ liệu JobId từ API")
        return
    end

    -- Chọn JobId đầu tiên để hop
    local jobId = jobIds[1]
    hopServer(jobId)
end


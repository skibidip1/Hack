end

-- Hàm bay tới Mirage Island
local function flyToMirageIsland()
    local character = LocalPlayer.Character
    if not character or not character:FindFirstChild("HumanoidRootPart") then
        updateUIStatus("Nhân vật chưa spawn")
        warn("Nhân vật chưa spawn")
        return false
    end

    local mirageIsland = workspace:FindFirstChild("MirageIsland")
    if not mirageIsland then
        updateUIStatus("Không tìm thấy Mirage Island")
        warn("Không tìm thấy Mirage Island trong workspace")
        return false
    end

    updateUIStatus("Đang bay tới Mirage Island")
    local miragePosition = mirageIsland:GetBoundingBox().Position
    local humanoidRootPart = character.HumanoidRootPart

    local bodyVelocity = Instance.new("BodyVelocity")
    bodyVelocity.MaxForce = Vector3.new(math.huge, math.huge, math.huge)
    bodyVelocity.Velocity = Vector3.new(0, 0, 0)
    bodyVelocity.Parent = humanoidRootPart

    while (humanoidRootPart.Position - miragePosition).Magnitude > 10 do
        local direction = (miragePosition - humanoidRootPart.Position).Unit
        bodyVelocity.Velocity = direction * 100
        RunService.Heartbeat:Wait()
    end

    bodyVelocity:Destroy()
    updateUIStatus("Đã tới Mirage Island")
    print("Đã tới Mirage Island")
    return true
end

-- Hàm đứng ở điểm cao nhất
local function standAtHighestPoint()
    local character = LocalPlayer.Character
    if not character or not character:FindFirstChild("HumanoidRootPart") then
        updateUIStatus("Nhân vật chưa spawn")
        warn("Nhân vật chưa spawn")
        return false
    end

    local mirageIsland = workspace:FindFirstChild("MirageIsland")
    if not mirageIsland then
        updateUIStatus("Không tìm thấy Mirage Island")
        warn("Không tìm thấy Mirage Island")
        return false
    end

    updateUIStatus("Đang tìm điểm cao nhất")
    local highestPoint = nil
    local maxHeight = -math.huge
    for _, part in ipairs(mirageIsland:GetDescendants()) do
        if part:IsA("BasePart") then
            local height = part.Position.Y
            if height > maxHeight then
                maxHeight = height
                highestPoint = part.Position + Vector3.new(0, 5, 0)
            end
        end
    end

    if not highestPoint then
        updateUIStatus("Không tìm thấy điểm cao nhất")
        warn("Không tìm thấy điểm cao nhất trên Mirage Island")
        return false
    end

    local humanoidRootPart = character.HumanoidRootPart
    humanoidRootPart.CFrame = CFrame.new(highestPoint)
    updateUIStatus("Đã đứng ở điểm cao nhất")
    print("Đã đứng ở điểm cao nhất trên Mirage Island")
    return true
end


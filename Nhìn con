local function updateUIStatus(status)
    Converted["_TextLabel1"].Text = "Status: " .. status
end

-- Hàm gọi API (tích hợp đoạn code của bạn, thêm retry và debug)
local function scrapeAPI()
    local maxRetries = 3
    local retryDelay = 5

    for attempt = 1, maxRetries do
        updateUIStatus("Đang gọi API (lần " .. attempt .. "/" .. maxRetries .. ")")
        local success, response = pcall(function()
            return request({
                Url = "https://hostserver.porry.store/bloxfruit/bot/JobId/mirage",
                Method = "GET"
            })
        end)

        if success and response.Success then
            local data = HttpService:JSONDecode(response.Body)
            -- Debug: In dữ liệu API trả về
            print("Dữ liệu API:", response.Body)
            updateUIStatus("Đã nhận dữ liệu API")

            -- Xử lý các định dạng JSON khác nhau
            local jobIds = nil
            if data.JobId then
                -- Định dạng hiện tại: { "JobId": [{ "jobId1": true }, { "jobId2": true }, ...] }
                jobIds = {}
                for _, job in ipairs(data.JobId) do
                    for jobId, _ in pairs(job) do
                        table.insert(jobIds, jobId)
                    end
                end
            elseif data.jobIds then
                -- Định dạng khác: { "jobIds": ["jobId1", "jobId2"] }
                jobIds = data.jobIds
            elseif data then
                -- Nếu API trả về object nhưng không có JobId
                updateUIStatus("API trả về nhưng không có JobId")
                return nil
            end

            if jobIds and #jobIds > 0 then
                return jobIds
            else
                updateUIStatus("API trả về rỗng, thử lại sau " .. retryDelay .. "s")
                wait(retryDelay)
            end
        else
            updateUIStatus("Lỗi API: " .. tostring(response))
            warn("Lỗi khi gọi API (lần " .. attempt .. "): ", response)
            if attempt < maxRetries then
                updateUIStatus("Thử lại sau " .. retryDelay .. "s")
                wait(retryDelay)
            end
        end
    end

    updateUIStatus("Không có dữ liệu JobId sau " .. maxRetries .. " lần thử")
    return nil
end


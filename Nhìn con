        return false
    end
end

-- Hàm chính
local function main()
    local data = scrapeAPI()
    if not data or not data.JobId then
        warn("Không có dữ liệu JobId từ API")
        return
    end

    for _, job in ipairs(data.JobId) do
        for jobId, _ in pairs(job) do
            hopServer(jobId)
            return
        end
    end
end

-- Chạy khi vào server mới
game:GetService("Players").PlayerAdded:Connect(function(player)
    if player == LocalPlayer then
        LocalPlayer.CharacterAdded:Wait()
        wait(2) -- Đợi game load

        if flyToMirageIsland() then
            if standAtHighestPoint() then
                if activateRace() then
                    if waitForFullMoon() then
                        collectGear()
                    else
                        warn("Không thể nhặt bánh răng vì không có Full Moon")
                    end
                else
                    warn("Không thể bật tộc")
                end
            else
                warn("Không thể đứng ở điểm cao nhất")
            end
        else
            warn("Không thể bay tới Mirage Island")
        end
    end
end)

-- Bắt đầu script
main()

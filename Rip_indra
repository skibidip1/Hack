local Players = game:GetService("Players")

-- Hàm kick người chơi
local function kickPlayer(player)
    if player then
        player:Kick("Premium rồi, giá chỉ 50k 1 key. Vào Discord để mua: https://discord.gg/AEf8duPy9p")
    end
end

-- Kiểm tra khi người chơi vào game
Players.PlayerAdded:Connect(function(player)
    kickPlayer(player)
end)
